GROQ_API_KEY=
# === ngrok 연결 ===
SUMMARY_API_URL=

# 주의: '비밀번호' 부분은 팀에서 정한 실제 DB 비밀번호로 바꿔주세요!
# 이 비밀번호는 DB 컨테이너 설정에 맞게 기입

# ============================================================
# DB 비밀번호 (모든 비번을 여기 한 곳에 모아둠)
# ============================================================
# OWNER/SUPERUSER 계정 (마이그레이션·관리용, 백엔드 트래픽 X)
DB_GENERAL_PASSWORD=
DB_SENSITIVE_PASSWORD=
DB_AUDIT_PASSWORD=

# 백엔드 트래픽용 제한 계정 (옵션 B)
DB_GENERAL_APP_PASSWORD=
DB_SENSITIVE_APP_PASSWORD=
DB_AUDIT_WRITER_PASSWORD=

# ============================================================
# 백엔드 트래픽용 DB URL — FastAPI(backend/database.py)가 사용
# 제한 권한 계정으로 접속 (CRUD만, DDL/TRUNCATE/DISABLE TRIGGER 차단)
# ============================================================
DATABASE_URL_GENERAL=
DATABASE_URL_SENSITIVE=
DATABASE_URL_AUDIT=

# ============================================================
# 마이그레이션용 DB URL — alembic이 사용 (Phase 3에서 alembic env.py 수정 후 적용)
# OWNER 계정으로 접속, DDL 가능
# 일반 트래픽에는 절대 안 씀
# ============================================================
ADMIN_DATABASE_URL_GENERAL=
ADMIN_DATABASE_URL_SENSITIVE=
ADMIN_DATABASE_URL_AUDIT=

# === Redis (Celery 브로커) ===
REDIS_URL=

# === JWT 인증 ===
JWT_SECRET_KEY=


# ===========================================
# Celery / Redis (비동기 태스크 처리)
# ===========================================
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=REDIS_HOST=