# .env.example
# 역할: 어떤 환경변수가 필요한지 알려주는 "빈 양식"
# 사용법: 이 파일을 .env로 복사하고, 본인 환경에 맞게 값을 채워서 사용

# === DB 비밀번호 (3개) ===
DB_GENERAL_PASSWORD=heartbeat1
DB_SENSITIVE_PASSWORD=heartbeat12
DB_AUDIT_PASSWORD=heartbeat123
DB_AUDIT_WRITER_PASSWORD=heartbeat123

# === DB 접속 문자열 (FastAPI가 사용) ===
# 형식: postgresql://사용자:비밀번호@호스트:포트/DB이름
# 주의: 호스트는 'localhost'가 아니라 docker-compose의 서비스명

# 일반 DB (운영 데이터): RW 권한
DATABASE_URL_GENERAL=postgresql://heartbeat:${DB_GENERAL_PASSWORD}@db_general:5432/heartbeat_general

# 민감 DB (임상 데이터): RW 권한
DATABASE_URL_SENSITIVE=postgresql://heartbeat:${DB_SENSITIVE_PASSWORD}@db_sensitive:5432/heartbeat_sensitive

# 감사 DB (감사 로그): 애플리케이션은 INSERT only 권장
DATABASE_URL_AUDIT=postgresql://heartbeat:${DB_AUDIT_PASSWORD}@db_audit:5432/heartbeat_audit

# 감사 DB Writer (감사 로그): 애플리케이션은 INSERT only 권장
DATABASE_URL_AUDIT_WRITER=postgresql://heartbeat:${DB_AUDIT_WRITER_PASSWORD}@db_audit:5432/heartbeat_audit

# === Redis (Celery 브로커) ===
REDIS_URL=redis://redis:6379/0

# === JWT 인증 ===
JWT_SECRET=
