# ============================================================
# 루트 .env — docker-compose가 ${...} 변수 치환에 사용
# (DB 컨테이너 비번 + api 컨테이너에 명시적 주입할 비번)
# 백엔드가 직접 읽는 변수(DATABASE_URL_*, REDIS_URL, JWT_*)는
# backend/.env에 둠
# ============================================================

# OWNER/SUPERUSER 계정 (DB 컨테이너 초기화 + 마이그레이션용)
DB_GENERAL_PASSWORD=
DB_SENSITIVE_PASSWORD=
DB_AUDIT_PASSWORD=

# 백엔드 트래픽용 제한 계정 (옵션 B)
DB_GENERAL_APP_PASSWORD=
DB_SENSITIVE_APP_PASSWORD=
DB_AUDIT_WRITER_PASSWORD=

# ============================================================

# === Redis (Celery 브로커) ===
REDIS_URL=

# === JWT 인증 ===
JWT_SECRET_KEY=
