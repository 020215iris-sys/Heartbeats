# .env.example
# 역할: 어떤 환경변수가 필요한지 알려주는 "빈 양식"
# 사용법: 이 파일을 .env로 복사하고, 본인 환경에 맞게 값을 채워서 사용

# === DB 비밀번호 ===
DB_MAIN_PASSWORD=
DB_AUDIT_PASSWORD=

# === DB 접속 문자열 (FastAPI가 사용) ===
# 형식: postgresql://사용자:비밀번호@호스트:포트/DB이름
# 주의: 호스트는 'localhost'가 아니라 docker-compose의 서비스명
DATABASE_URL_MAIN=postgresql://heartbeat:CHANGE_ME@db_main:5432/heartbeat_main
DATABASE_URL_AUDIT=postgresql://heartbeat:CHANGE_ME@db_audit:5432/heartbeat_audit

# === Redis (Celery 브로커) ===
REDIS_URL=redis://redis:6379/0

# === JWT 인증 ===
JWT_SECRET=